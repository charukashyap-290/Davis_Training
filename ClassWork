        "#write a program to find the number of vowles in the given file.\n",
        "\n",
        "# Open the file in read mode\n",
        "file = open(\"sample.txt\", \"r\")\n",
        "\n",
        "text = file.read()\n",
        "\n",
        "# Initialize vowel count\n",
        "count = 0\n",
        "\n",
        "# Define vowels\n",
        "vowels = \"aeiouAEIOU\"\n",
        "\n",
        "# Count vowels\n",
        "for ch in text:\n",
        "    if ch in vowels:\n",
        "        count += 1\n",
        "\n",
        "print(\"Number of vowels in file:\", count)\n",
        "\n",
        "file.close()"
