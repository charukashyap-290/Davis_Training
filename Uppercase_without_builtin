# This program converts string to uppercase without using upper()

# Take input
s = input("Enter string: ")

result = ""

# Loop through each character
for ch in s:
    if 'a' <= ch <= 'z':   # check if lowercase
        result += chr(ord(ch) - 32)   # convert to uppercase
    else:
        result += ch

# Print result
print(result)

# Output:
# Enter string: abc
# ABC
